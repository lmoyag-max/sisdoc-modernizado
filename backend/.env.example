# ================================
# SISDOC Backend — Variables de entorno
# ================================

# Servidor
NODE_ENV=development
PORT=3001

# Base de datos SQL Server (mssql directo)
DB_USER=sa
DB_PASSWORD=Adminhuap2026!
DB_SERVER=localhost
DB_PORT=1433
DB_DATABASE=SISDOC
DB_TRUST_CERT=true
DB_ENCRYPT=false

# Prisma (alternativo, mismos datos)
DATABASE_URL="sqlserver://localhost:1433;database=SISDOC;user=sa;password=Adminhuap2026!;encrypt=false;trustServerCertificate=true"

# JWT
JWT_SECRET=super-secret-jwt-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=super-secret-refresh-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Archivos
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=20971520
